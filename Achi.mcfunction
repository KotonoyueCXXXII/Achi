editpopupform ACHI_INFO_ERROR content "errorCode = {func, function.call('data/mapGet', 'temp.menu.errorCode', 'code')} | if errorCode == 1: | return '未选择目标' | elif errorCode == 2: | return '目标玩家状态已变更，请返回重试' | elif errorCode == 3: | return '快照已失效，请重新打开玩家列表' | elif errorCode == 4: | return '所选槽位无玩家' | elif errorCode == 5: | return '权限不足' | elif errorCode == 6: | return '暂无可用地皮，请联系管理员添加' | elif errorCode == 7: | return '你已拥有地皮，无法再次获取' | elif errorCode == 8: | return '目标玩家尚未注册' | elif errorCode == 9: | return '请先注册后再使用此功能' | elif errorCode == 10: | return '地皮初始化超时，请稍后重试' | elif errorCode == 11: | return '目标玩家未获取地皮' | elif errorCode == 12: | return '该锚点尚未设置坐标' | elif errorCode == 13: | return '未选择锚点槽位' | elif errorCode == 14: | return '没有在你脚下的位置找到地皮' | elif errorCode == 15: | return '密码错误' | elif errorCode == 16: | return '该地皮正在备份中，请稍后再试' | elif errorCode == 17: | return '目标玩家未开放传送权限' | elif errorCode == 18: | return '指定的数据域不存在' | else: | return '未知错误，错误码：' + str(errorCode) | fi"
