editpopupform ACHI_INFO_RESTORE content "return '系统检测到您在本房间内保有建筑数据，点击确定将自动为您找到合适地皮并加载您的建筑。'"
editpopupform ACHI_INFO_RESTORE button1 "return '确定恢复'"
editpopupform ACHI_INFO_RESTORE button2 "return '稍后再说'"
customform onsubmit ACHI_INFO_RESTORE "playerId = {func, command.get_executor()} | if {ref, bool, 1}: | playerData = {func, function.call('data/ptrMapGet', 'data.player.archive', playerId)} | _ = {func, object.finalise(playerData)} | playerUID = {func, maps.get(playerData, 'uid')} | savedSizeIndex = {func, maps.get(playerData, 'saveSizeIndex')} | freeLandIndex = {func, function.call('land/getFreeIndex', savedSizeIndex)} | if freeLandIndex == -2147483648: | _ = {func, function.call('entry/showError', 6)} | return True | fi | landData = {func, function.call('data/ptrMapGet', 'data.land.archive', freeLandIndex)} | _ = {func, object.finalise(landData)} | anchor_x = {func, maps.get(landData, 'anchor_x')} | anchor_y = {func, maps.get(landData, 'anchor_y')} | anchor_z = {func, maps.get(landData, 'anchor_z')} | sizeIndex = savedSizeIndex | landSize = 20 + sizeIndex * 10 - 1 | centerOffset = {func, math.floordiv(landSize, 2)} | center_x = anchor_x + centerOffset | center_z = anchor_z + centerOffset | center_y = anchor_y + 64 | _ = {func, entity.SetPos(playerId, {func, tuple.new(center_x, center_y, center_z)})} | playerIndex = {func, function.call('data/mapKeyOf', 'temp.player.index',playerId)} | _ = {func, function.call('data/mapSet', 'temp.land.using', playerIndex,freeLandIndex)} | taskMap = {func, maps.new(False)} | _ = {func, maps.set(taskMap, 'playerUID', playerUID)} | _ = {func, maps.set(taskMap, 'playerId', playerId)} | _ = {func, maps.set(taskMap, 'mode', 1)} | _ = {func, maps.set(taskMap, 'landIndex', freeLandIndex)} | _ = {func, maps.set(taskMap, 'state', 0)} | _ = {func, maps.set(taskMap, 'retry', 0)} | _ = {func, maps.set(taskMap, 'playerIndex', playerIndex)} | _ = {func, function.call('queue/push', 'queue.land.backup', taskMap)} | _ = {func, function.call('entry/navigate', 'ACHI_HOME_LAND')} | _ = {func, function.call('entry/feedback', '已为您分配地皮并提交恢复请求，建筑正在恢复中。')} | fi | return True"
customform save ACHI_INFO_RESTORE
customfunction call @p ~ ~ ~ "init/main"
customfunction call @p ~ ~ ~ "init/verify"
systemevent destroy on_command
systemevent listen GlobalCommandServerEvent on_command "rawCmd = {func, maps.get(args, 'command')} | if {func, maps.exist(args, 'entityId')}: | if {func, strings.startswith(rawCmd, '/')}: | entityId = {func, maps.get(args, 'entityId')} | _ = {func, command.set_executor(entityId)} | _ = {func, maps.set(args, 'cancel', True)} | playerData = {func, function.call('data/ptrMapGet', 'data.player.archive', entityId)} | if playerData != -2147483648: | if {func, maps.get(playerData, 'privilegeLevel')} > 2: | _ = {func, maps.set(args, 'cancel', False)} | else: | _ = {func, function.call('entry/feedback', '权限不足，仅管理员可使用命令\\n' + rawCmd)} | fi | _ = {func, object.finalise(playerData)} | else: | _ = {func, function.call('entry/feedback', '请先注册后再使用命令')} | fi | fi | fi | return True"