customform onsubmit ACHI_HOME_PLAYER_ACTION "playerId = {func, command.get_executor()} | playerIndex = {func, function.call('data/mapKeyOf', 'temp.player.index', playerId)} | playerData = {func, function.call('data/ptrMapGet', 'data.player.archive', playerId)} | _ = {func, object.finalise(playerData)} | privilege = {func, maps.get(playerData, 'privilegeLevel')} | err = {func, function.call('ui/validatePlayerSelection', playerIndex)} | if err != 0: | _ = {func, function.call('entry/showError', err)} | return True | fi | settingPlayerIndex = {func, function.call('data/mapGet', 'temp.menu.settingPlayer', playerIndex)} | targetId = {func, function.call('data/mapGet', 'temp.player.index', settingPlayerIndex)} | targetName = {func, object.deref({func, entity.GetName(targetId)})} | if {ref, bool, 0}: | if privilege != 3: | targetPlayerData = {func, function.call('data/ptrMapGet', 'data.player.archive', targetId)} | if targetPlayerData == -2147483648: | _ = {func, function.call('entry/showError', 17)} | return True | fi | _ = {func, object.finalise(targetPlayerData)} | if not {func, maps.get(targetPlayerData, 'allowTPToMe')}: | _ = {func, function.call('entry/showError', 17)} | return True | fi | fi | targetPos = {func, entity.GetFootPos(targetId)} | _ = {func, entity.SetPos(playerId, targetPos)} | _ = {func, function.call('entry/feedback', '已传送至目标玩家')} | elif {ref, bool, 1}: | _ = {func, function.call('entry/navigate', 'ACHI_HOME_PLAYER_MESSAGE')} | elif {ref, bool, 2}: | if privilege == 3: | cmd = 'kick \"' + targetName + '\"' | _ = {func, world.SetCommand(cmd, playerId)} | else: | _ = {func, function.call('entry/showError', 5)} | fi | elif {ref, bool, 3}: | elif {ref, bool, 4}: | if privilege == 3: | targetPlayerData = {func, function.call('data/ptrMapGet', 'data.player.archive', targetId)} | if targetPlayerData == -2147483648: | _ = {func, function.call('entry/showError', 8)} | return True | fi | _ = {func, object.finalise(targetPlayerData)} | if not {func, function.call('data/mapExist', 'temp.land.using', settingPlayerIndex)}: | _ = {func, function.call('entry/showError', 11)} | return True | fi | _ = {func, function.call('data/mapDel', 'temp.land.using', settingPlayerIndex)} | _ = {func, maps.del(targetPlayerData, 'saveSizeIndex')} | _ = {func, command.set_executor(targetId)} | _ = {func, function.call('entry/feedback', '你的地皮已被管理员解除绑定')} | _ = {func, command.set_executor(playerId)} | else: | _ = {func, function.call('entry/showError', 5)} | fi | elif {ref, bool, 5}: | if privilege == 3: | _ = {func, function.call('entry/navigate', 'ACHI_HOME_PLAYER_ADMIN')} | else: | _ = {func, function.call('entry/showError', 5)} | fi | fi | return True"
