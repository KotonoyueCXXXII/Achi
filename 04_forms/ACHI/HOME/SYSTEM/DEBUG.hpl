// 提交处理
customform onsubmit &(formName) "
playerId = {func, command.get_executor()}
worldId = {func, object.deref({func, world.GetLevelId()})}

// 元素 0 — 输入框：清除指定数据域
domainName = {ref, str, 0}

if domainName != '':
  domainPtr = {func, entity.GetExtraData(worldId, domainName)}

  if {func, object.ref_type(domainPtr)} != 6:
    _ = {func, function.call('entry/showError', 18)}
    return True
  fi

  _ = {func, entity.CleanExtraData(worldId, domainName)}
  msg = '已清除数据域: ' + domainName
  _ = {func, function.call('entry/feedback', msg)}
fi

// 元素 1 — 开关：同步调试标签
useDebug = {ref, bool, 1}

if useDebug:
  _ = {func, entity.AddEntityTag(playerId, 'isDebugMode')}
  _ = {func, function.call('entry/feedback', '已开启调试模式')}
else:
  _ = {func, entity.RemoveEntityTag(playerId, 'isDebugMode')}
  _ = {func, function.call('entry/feedback', '已关闭调试模式')}
fi

_ = {func, function.call('entry/navigate', 'ACHI_HOME_SYSTEM')}
return True
"

// 取消处理：返回系统设置
customform oncancel &(formName) "
_ = {func, function.call('entry/navigate', 'ACHI_HOME_SYSTEM')}
"
