// 输入框：数据域名称
editmodalform &(formName) append input
editinput &(formName) 0 text "return '输入要删除的数据的域名'"
editinput &(formName) 0 placeholder "return '例如: data.player.archive'"
editinput &(formName) 0 tooltip "return '输入要清除的 ExtraData 数据域名称，清除操作不可撤销'"

// 开关：调试广播 — 开启时结果通过 entry/debug 向全服广播，关闭时仅 feedback 当前玩家
editmodalform &(formName) append toggle
edittoggle &(formName) 1 text "return '调试广播'"
edittoggle &(formName) 1 default "
playerId = {func, command.get_executor()}
hasTag = {func, entity.EntityHasTag(playerId, 'isDebugMode')}
return {func, object.deref(hasTag)}
"
edittoggle &(formName) 1 tooltip "return '开启后系统调试信息将向你广播（需 isDebugMode 标签），关闭则不再接收'"

