// 下拉菜单：权限等级选择
editmodalform &(formName) append dropdown
editdropdown &(formName) 0 text "return '设置权限等级'"
editdropdown &(formName) 0 append "return '- 访客 -'"
editdropdown &(formName) 0 append "return '- 成员 -'"
editdropdown &(formName) 0 append "return '- 会员 -'"
editdropdown &(formName) 0 append "return '- 管理员 -'"

// 默认选中目标玩家当前的权限等级
editdropdown &(formName) 0 default "
playerId = {func, command.get_executor()}
playerIndex = {func, function.call('data/mapKeyOf', 'temp.player.index', playerId)}
settingPlayerIndex = {func, function.call('data/mapGet', 'temp.menu.settingPlayer', playerIndex)}
targetPlayerId = {func, function.call('data/mapGet', 'temp.player.index', settingPlayerIndex)}

if targetPlayerId == -2147483648:
  return 0
fi

targetPlayerData = {func, function.call('data/ptrMapGet', 'data.player.archive', targetPlayerId)}
//由于使用此界面的前提是创建账户，故此处不进行返回值检查
_ = {func, object.finalise(targetPlayerData)}
return {func, maps.get(targetPlayerData, 'privilegeLevel')}
"

// 提交处理：验证并获取目标玩家信息
customform onsubmit &(formName) "
playerId = {func, command.get_executor()}
playerIndex = {func, function.call('data/mapKeyOf', 'temp.player.index', playerId)}
err = {func, function.call('ui/validatePlayerSelection', playerIndex)}

if err != 0:
  _ = {func, function.call('entry/showError', err)}
  return True
fi

settingPlayerIndex = {func, function.call('data/mapGet', 'temp.menu.settingPlayer', playerIndex)}
targetPlayerId = {func, function.call('data/mapGet', 'temp.player.index', settingPlayerIndex)}
targetName = {func, object.deref({func, entity.GetName(targetPlayerId)})}

// 设置目标玩家权限等级
newLevel = {ref, int, 0}
targetPlayerData = {func, function.call('data/ptrMapGet', 'data.player.archive', targetPlayerId)}
_ = {func, object.finalise(targetPlayerData)}
_ = {func, maps.set(targetPlayerData, 'privilegeLevel', newLevel)}
_ = {func, function.call('entry/feedback', '已将' + targetName + '的权限设置为' + str(newLevel))}
return True
"

// 取消处理：返回玩家操作界面
customform oncancel &(formName) "
_ = {func, function.call('entry/navigate', 'ACHI_HOME_PLAYER_ACTION')}
"
