editlongform &(formName) content "return '请选择你期望的地皮大小， 尽量选择较小尺寸的地皮'"
editlongform &(formName) append button
editbutton &(formName) 0 text "return '20\*20'"
editlongform &(formName) append button
editbutton &(formName) 1 text "return '30\*30'"
editlongform &(formName) append button
editbutton &(formName) 2 text "return '40\*40'"

customform onsubmit &(formName) "
// 获取选择的地皮尺寸
landSizeIndex = {ref, int, -1}

// 获取玩家上下文
playerId = {func, command.get_executor()}
playerIndex = {func, function.call('data/mapKeyOf', 'temp.player.index', playerId)}

// 检查是否已有地皮

if {func, function.call('data/mapExist', 'temp.land.using', playerIndex)}:
  _ = {func, function.call('entry/showError', 7)}
  return True
fi

// 查找空闲地皮
freeLandIndex = {func, function.call('land/getFreeIndex', landSizeIndex)}

if freeLandIndex == -2147483648:
  _ = {func, function.call('entry/showError', 6)}
  return True
fi

// 绑定地皮到玩家
_ = {func, function.call('data/mapSet', 'temp.land.using', playerIndex, freeLandIndex)}

// 计算地皮中心坐标
landData = {func, function.call('data/ptrMapGet', 'data.land.archive', freeLandIndex)}
//此处不必验证，该索引的地皮数据已经通过'land/getFreeIndex'验证
_ = {func, object.finalise(landData)}
anchor_x = {func, maps.get(landData, 'anchor_x')}
anchor_y = {func, maps.get(landData, 'anchor_y')}
anchor_z = {func, maps.get(landData, 'anchor_z')}
landSize = 20 + landSizeIndex * 10 - 1
centerOffset = {func, math.floordiv(landSize, 2)}
center_x = anchor_x + centerOffset
center_y = anchor_y + 16
center_z = anchor_z + centerOffset

// 传送至地皮中心
_ = {func, entity.SetPos(playerId, {func, tuple.new(center_x, center_y, center_z)})}

// 提交初始化任务
taskMap = {func, maps.new(False)}
_ = {func, maps.set(taskMap, 'landIndex', freeLandIndex)}
_ = {func, maps.set(taskMap, 'sizeIndex', landSizeIndex)}
_ = {func, maps.set(taskMap, 'playerId', playerId)}
_ = {func, maps.set(taskMap, 'anchor_x', anchor_x)}
_ = {func, maps.set(taskMap, 'anchor_y', anchor_y)}
_ = {func, maps.set(taskMap, 'anchor_z', anchor_z)}
_ = {func, maps.set(taskMap, 'retryCount', 15)}
queueKey = {func, function.call('queue/push', 'queue.land.init', taskMap)}
_ = {func, function.call('entry/feedback', '地皮已分配，初始化将在区块加载后自动完成。')}
return True
"

customform oncancel &(formName) "
// 返回地皮操作
_ = {func, function.call('entry/navigate', 'ACHI_HOME_LAND')}
"