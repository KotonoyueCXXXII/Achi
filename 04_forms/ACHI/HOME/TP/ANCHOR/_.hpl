editbutton &(formName) 0 text "playerId = {func, command.get_executor()}
return {func, function.call('ui/getAnchorButtonText', 1, playerId)}"
editbutton &(formName) 1 text "playerId = {func, command.get_executor()}
return {func, function.call('ui/getAnchorButtonText', 2, playerId)}"
editbutton &(formName) 2 text "playerId = {func, command.get_executor()}
return {func, function.call('ui/getAnchorButtonText', 3, playerId)}"
editbutton &(formName) 3 text "playerId = {func, command.get_executor()}
return {func, function.call('ui/getAnchorButtonText', 4, playerId)}"
editbutton &(formName) 4 text "playerId = {func, command.get_executor()}
return {func, function.call('ui/getAnchorButtonText', 5, playerId)}"
editbutton &(formName) 5 text "playerId = {func, command.get_executor()}
return {func, function.call('ui/getAnchorButtonText', 6, playerId)}"
editbutton &(formName) 6 text "playerId = {func, command.get_executor()}
